{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "A food category (e.g., Starters, Main Course)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "A dish on the menu",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "categoryId": { "type": "string" },
        "image": { "type": "string" },
        "isAvailable": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "categoryId"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "tableNumber": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "totalPrice": { "type": "number" },
        "status": { 
          "type": "string",
          "enum": ["Pending", "Preparing", "Served", "Cancelled"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerName", "tableNumber", "items", "totalPrice", "status", "createdAt"]
    }
  },
  "firestore": {
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of food categories"
    },
    "/menu/{menuItemId}": {
      "schema": "MenuItem",
      "description": "Collection of menu items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    }
  }
}
